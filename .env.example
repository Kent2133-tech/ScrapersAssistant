# ─────────────────────────────────────────
#  TAMBANG BOT — Environment Variables
#  Copy file ini jadi .env, lalu isi nilainya
# ─────────────────────────────────────────

# 1. Token bot dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=isi_token_bot_kamu_di_sini

# 2. Chat ID kamu (owner)
#    Cara dapat: chat ke @userinfobot di Telegram
OWNER_CHAT_ID=isi_chat_id_kamu

# 3. Supabase (sudah ada dari sistem tambang)
SUPABASE_URL=https://tqmqdrifrbvupkrufecc.supabase.co
SUPABASE_KEY=sb_publishable_bQTJDIyQYhx6P3Wljt82JA_gJmnFud1

# 4. Anthropic API Key (untuk fitur Tanya AI)
#    Dapat dari: console.anthropic.com
#    Kalau tidak mau pakai fitur AI, kosongkan saja
ANTHROPIC_API_KEY=

# 5. Chat ID operator (pisah dengan koma, tanpa spasi)
#    Cara dapat: suruh operator chat ke @userinfobot
#    Contoh: OPERATOR_IDS=123456789,987654321
OPERATOR_IDS=
